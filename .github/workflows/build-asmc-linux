name: Build Asmc on manylinux

on:
  push:
    branches: [ main, master ]
  pull_request:
    branches: [ main, master ]
  workflow_dispatch:   # 支持手动触发

jobs:
  build:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        include:
          - image: quay.io/pypa/manylinux2014_x86_64
            label: manylinux2014
          - image: quay.io/pypa/manylinux_2_28_x86_64
            label: manylinux_2_28
    container:
      image: ${{ matrix.image }}

    steps:
      - name: 检出代码
        uses: actions/checkout@v4

      - name: 安装编译工具（gcc、make）
        run: |
          # manylinux 镜像自带 gcc，但为保证版本一致，显式安装
          yum install -y gcc make
          gcc --version

      - name: 编译 asmc
        run: make all

      - name: 列出产物
        run: ls -la

      - name: 上传二进制工件（按环境区分）
        uses: actions/upload-artifact@v4
        with:
          name: asmc-${{ matrix.label }}
          path: ./asmc